# Database (required)
POSTGRES_USER=mb_user
POSTGRES_PASSWORD=mb_password
POSTGRES_DB=mb_database
DATABASE_URL=postgresql://mb_user:mb_password@localhost:5432/mb_database

# Redis (optional)
REDIS_URL=redis://localhost:6379

# JWT (required, min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-32chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-32chars

# API
NODE_ENV=development
API_PORT=9000
API_PREFIX=/api/v1

# CORS
ALLOW_ORIGIN=http://localhost:3000,http://localhost:5173

# Cookie
COOKIE_SECURE=false

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Mail (optional)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=noreply@example.com

# WeApp (optional)
WEAPP_APPID=your-weapp-appid
WEAPP_SECRET=your-weapp-secret

# WeChat OAuth (optional)
WECHAT_REDIRECT_URI=https://your-domain.com/auth/wechat/callback

# Frontend
VITE_API_BASE_URL=http://localhost:9000

# Database Backup (optional; 本机无 pg_dump 时用 Docker 容器内的)
# 恢复请用 pnpm db:restore（psql 原生格式，不要用 Navicat 执行）
BACKUP_CMD=docker exec mb-postgres pg_dump -U mb_user mb_database > "{filepath}"
